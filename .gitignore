# Python virtual environment
venv/

dashboard/
.caches/
# Evaluation output — ignored locally; CI force-adds them to result branches.
# Patterns only match files directly in results/ (not in provider subdirs like
# results/openai/ or results/google/) so the provider trees are unaffected.
results/*.csv
results/*.json
results/graphs/
# Per-run detail pages generated by generate_results.py (live in results/)
results/*.md
# Top-level aggregated summary
RESULTS.md
# Dashboard staging area
dashboard_results/

# Vector database (extracted from kiali-byok image via make setup-vector-db)
vector_db/

# Embedding model (downloaded via make get-embeddings-model)
embeddings_model/

# Pip temp files
/tmp/.pip-*.log

# Python cache
__pycache__/
*.pyc
*.pyo

# MCP server temp configs
/tmp/mcp-config-*.toml
